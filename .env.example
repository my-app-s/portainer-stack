# =====================================================================
# Шаблон конфигурации Portainer + Traefik Edge Gateway
# =====================================================================

# --- Настройки контейнеров ---
# VERSION_T=версия traefik
# VERSION_P=версия portainer
# TELEMETRY=отключение телеметрии для portainer
VERSION_T=v3.0
VERSION_P=latest
TELEMETRY=-no-analytics

# --- Настройки сети и портов ---
# Раскомментируйте, измените если порты 80 или 443 на сервере уже заняты:
# FORWARD_PORT_HTTP=8080
# FORWARD_PORT_HTTPS=8443

# --- Настройки домена и SSL (Для продакшена) ---
# Для локального теста оставьте localhost. Для продакшен сервера укажите ваш домен:
DOMAIN=localhost

# Чтобы включить настоящий бесплатный SSL (Let's Encrypt):
# 1. Укажите example: CERT_RESOLVER=myresolver
# 2. Укажите ваш реальный Email для уведомлений
CERT_RESOLVER=
ACME_EMAIL=