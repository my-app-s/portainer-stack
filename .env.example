# =====================================================================
# Portainer + Traefik Edge Gateway Configuration Template
# =====================================================================

# Uncomment the parameters that are necessary.

# --- Container settings ---
#VERSION_T=latest
#VERSION_P=latest

# --- Network and port settings ---
# Change if ports 80 or 443 are already occupied on the server:
# FORWARD_PORT_HTTP=8080
#FORWARD_PORT_HTTPS=8443

# --- Local/Development Mode ---
# For local testing, leave it as localhost.
#DOMAIN=192.168.1.1
#CERT_RESOLVER=

# --- Production Mode ---
# To enable real free SSL (Let's Encrypt):
#DOMAIN=your-domain.com
#CERT_RESOLVER=myresolver
#ACME_EMAIL=your@mail.domain